typedef  enum {
   MT_MIX,
   MT_ADD,
} mixType;
I mixCol(I c1, I c2, F pow, mixType t){
   if(pow < 0) pow = 0; if(pow > 1) pow = 1;
   I a1 = (c1 >> 24) & 0xFF;
   I r1 = (c1 >> 16) & 0xFF;
   I g1 = (c1 >> 8)  & 0xFF;
   I b1 =  c1        & 0xFF;

   I a2 = (c2 >> 24) & 0xFF;
   I r2 = (c2 >> 16) & 0xFF;
   I g2 = (c2 >> 8)  & 0xFF;
   I b2 =  c2        & 0xFF;

   I a = 0; I r = 0; I g = 0; I b = 0;
   if (t==MT_MIX){
      a = (I)(a2 + ((a1-a2)*pow));
      r = (I)(r2 + ((r1-r2)*pow));
      g = (I)(g2 + ((g1-g2)*pow));
      b = (I)(b2 + ((b1-b2)*pow));
   }ef(t==MT_ADD){
      a = a2 + (I)(a1 * pow); if (a > 0xFF) a = 0xFF;
      r = r2 + (I)(r1 * pow); if (r > 0xFF) r = 0xFF;
      g = g2 + (I)(g1 * pow); if (g > 0xFF) g = 0xFF;
      b = b2 + (I)(b1 * pow); if (b > 0xFF) b = 0xFF;
   }
   return (a << 24) | (r << 16) | (g << 8) | b;
}
